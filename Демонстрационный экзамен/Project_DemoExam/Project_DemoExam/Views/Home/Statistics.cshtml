@model Project_DemoExam.ViewModels.StatisticsViewModel

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Статистика</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center">
            <h2>Статистика</h2>
            <a class="btn btn-outline-secondary" href="/Home/Index">Назад</a>
        </div>
        <hr />

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="border rounded bg-white p-3">
                    <div class="text-muted">Выполненных заявок</div>
                    <div class="fs-3">@Model.CompletedCount</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded bg-white p-3">
                    <div class="text-muted">Среднее время ремонта (дней)</div>
                    <div class="fs-3">@(Model.AverageRepairDays is null ? "—" : Model.AverageRepairDays.Value.ToString("0.0"))</div>
                </div>
            </div>
        </div>

        <div class="border rounded bg-white p-3">
            <h5 class="mb-3">Топ-10 типов неисправностей (по описанию)</h5>

            @if (Model.FaultTypeStats.Count == 0)
            {
                <div class="alert alert-info mb-0">Нет данных для построения статистики.</div>
            }
            else
            {
                <table class="table table-bordered mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Неисправность</th>
                            <th style="width: 140px;">Количество</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.FaultTypeStats)
                        {
                            <tr>
                                <td>@row.FaultType</td>
                                <td>@row.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</body>
</html>

