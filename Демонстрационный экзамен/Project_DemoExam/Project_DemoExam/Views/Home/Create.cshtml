@model Project_DemoExam.ViewModels.RequestCreateViewModel

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Новая заявка</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center">
            <h2>Новая заявка</h2>
            <a class="btn btn-outline-secondary" href="/Home/Index">Назад</a>
        </div>
        <hr />

        <form method="post" action="/Home/Create" class="bg-white border rounded p-3">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary()
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Тип оборудования</label>
                <input class="form-control" name="Orgtechtype" value="@Model.Orgtechtype" />
                <div class="text-danger">@Html.ValidationMessageFor(m => m.Orgtechtype)</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Модель</label>
                <input class="form-control" name="Orgtechmodel" value="@Model.Orgtechmodel" />
                <div class="text-danger">@Html.ValidationMessageFor(m => m.Orgtechmodel)</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Описание проблемы</label>
                <textarea class="form-control" name="Problemdesc" rows="4">@Model.Problemdesc</textarea>
                <div class="text-danger">@Html.ValidationMessageFor(m => m.Problemdesc)</div>
            </div>

            @if (User.IsInRole("Client"))
            {
                <div class="mb-3">
                    <label class="form-label">ФИО заказчика</label>
                    <input class="form-control" value="@Model.ClientFio" readonly />
                    <div class="form-text">Заявка будет создана от вашего имени.</div>
                </div>
            }
            else
            {
                <div class="mb-3">
                    <label class="form-label">Заказчик</label>
                    <select class="form-select" name="ClientId">
                        <option value="">Выберите заказчика</option>
                        @if (Model.Clients != null)
                        {
                            foreach (var c in Model.Clients)
                            {
                                <option value="@c.Value" selected="@(c.Value == (Model.ClientId?.ToString() ?? ""))">@c.Text</option>
                            }
                        }
                    </select>
                    <div class="text-danger">@Html.ValidationMessage("ClientId")</div>
                    <div class="form-text">Выберите клиента, который обратился по телефону.</div>
                </div>
            }

            <button type="submit" class="btn btn-primary">Сохранить</button>
        </form>
    </div>
</body>
</html>

